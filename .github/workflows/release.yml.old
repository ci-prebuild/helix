name: Release
on:
  push:
    tags:
    - '[0-9]+.[0-9]+'
    - '[0-9]+.[0-9]+.[0-9]+'
    branches:
    - 'patch/ci-release-*'
    - 'main'
  pull_request:
    paths:
    - '.github/workflows/release.yml'

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: false

permissions:
  contents: read

env:
  # Preview mode: Publishes the build output as a CI artifact instead of creating
  # a release, allowing for manual inspection of the output. This mode is
  # activated if the CI run was triggered by events other than pushed tags, or
  # if the repository is a fork.
  preview: ${{ !startsWith(github.ref, 'refs/tags/') || github.repository != 'ci-prebuild/helix' }}

jobs:
  build:
    name: Build ${{ matrix.build }}
    env:
      # Emit backtraces on panics.
      RUST_BACKTRACE: 1
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false # don't fail other jobs if one fails
      matrix:
        build: [amd64, arm64]
        include:
        - build: amd64
          # WARN: When changing this to a newer version, make sure that the GLIBC isnt too new, as this can cause issues
          # with portablity on older systems that dont follow ubuntus more rapid release cadence.
          # os: ubuntu-22.04
          os: ubuntu-latest
          rust: stable
          cross: true
          # target: x86_64-unknown-linux-gnu
          target: x86_64-unknown-linux-musl
        - build: arm64
          # Version should be kept in lockstep with the x86_64 version
          # os: ubuntu-22.04-arm
          os: ubuntu-latest
          rust: stable
          cross: true
          # target: aarch64-unknown-linux-gnu
          target: aarch64-unknown-linux-musl

    steps:
      - name: Checkout sources
        uses: actions/checkout@v7
        with:
          repository: "helix-editor/helix"
          ref: "14d6bc0febed9c692048271a8ae2362ac969c6e0"

      # The rust-toolchain action ignores rust-toolchain.toml files.
      # Removing this before building with cargo ensures that the rust-toolchain
      # is considered the same between installation and usage.
      - name: Remove the rust-toolchain.toml file
        run: rm rust-toolchain.toml

      - name: Install ${{ matrix.rust }} toolchain
        uses: dtolnay/rust-toolchain@fa04a1451ff1842e2626ccb99004d0195b455a88 # master
        with:
          toolchain: ${{ matrix.rust }}
          target: ${{ matrix.target }}

      # Install a pre-release version of Cross
      # TODO: We need to pre-install Cross because we need cross-rs/cross#591 to
      #       get a newer C++ compiler toolchain. Remove this step when Cross
      #       0.3.0, which includes cross-rs/cross#591, is released.
      - name: Install Cross
        if: "matrix.cross"
        run: |
          cargo install cross --git https://github.com/cross-rs/cross.git --rev 47df5c76e7cba682823a0b6aa6d95c17b31ba63a
          echo "CARGO=cross" >> $GITHUB_ENV
        # echo "TARGET_FLAGS=--target ${{ matrix.target }}" >> $GITHUB_ENV
        # echo "TARGET_DIR=./target/${{ matrix.target }}" >> $GITHUB_ENV

      - name: Show command used for Cargo
        run: |
          echo "target flag is: ${{ env.TARGET_FLAGS }}"

      - name: Fetch tree-sitter grammars
        run: ${{ env.CARGO }} run --target ${{ matrix.target }} --package=helix-loader --bin=hx-loader

      - name: Build release binary
        run: ${{ env.CARGO }} build --profile opt --locked --target ${{ matrix.target }}

      - name: Install cargo-deb
        # if: matrix.build == 'x86_64-linux'
        uses: taiki-e/install-action@16b05812d776ae1dfaabc8277e421fb6d2506419 # v2.82.7
        with:
          tool: cargo-deb

      - name: Build ${{ matrix.build }}.deb
        shell: bash
        # if: matrix.build == 'x86_64-linux'
        run: |
          mkdir -p target/${{ matrix.target }}/release
          cp target/${{ matrix.target }}/opt/hx target/${{ matrix.target }}/release/
          # Change reference in deb file
          #   from `source = "target/release/hx"`
          #   to   `source = "target/${{ matrix.target }}/opt/hx"`
          #
          # Otherwise:
          #   - cargo-deb without --target fails on arm64 with weird linker issues
          #   - cargo-deb with target complains that target/FOO/release does not exist
          #
          # Actually maybe we just need to copy it to the release profile??
          # sed -i 's/source = "target\/release\/hx"/source = "target\/${{ matrix.target }}\/opt\/hx"/' 
          # We add no-strip because the release binary was already stripped
          # in previous step, and otherwise it will fail badly with this error:
          # strip: Unable to recognise the format of the input file `/home/runner/work/helix/helix/target/aarch64-unknown-linux-musl/release/hx'
          # error: Unable to strip binary '/home/runner/work/helix/helix/target/aarch64-unknown-linux-musl/release/hx': strip: exit status: 1
          # note: Target-specific strip commands are configured in /home/runner/work/helix/helix/.cargo/config.toml: `[target.aarch64-unknown-linux-musl] strip = { path = "strip" }`
          cargo deb --target ${{ matrix.target }} --no-build --no-strip
          # To know about future filenames
          ls target/debian/

      - name: Upload ${{ matrix.build }}.deb to artifacts
        uses: actions/upload-artifact@v7
        if: env.preview == 'true'
        with:
          name: helix_25.7.1-1_${{ matrix.build }}.deb
          path: target/debian/helix_25.7.1-1_${{ matrix.build }}.deb
          archive: false

      - name: Upload ${{ matrix.build }}.deb to release
        uses: svenstaro/upload-release-action@29e53e917877a24fad85510ded594ab3c9ca12de # 2.11.5
        if: env.preview == 'false'
        with:
          repo_token: ${{ secrets.GITHUB_TOKEN }}
          file: dist/helix_25.7.1-1_${{ matrix.build }}.deb
          tag: ${{ github.ref_name }}
          overwrite: true

      - name: Prepare dist for ${{ matrix.build }}.tar.xz
        shell: bash
        run: |
          mkdir -p dist
          if [ "${{ runner.os }}" = "Windows" ]; then
            cp "target/${{ matrix.target }}/opt/hx.exe" "dist/"
          else
            cp "target/${{ matrix.target }}/opt/hx" "dist/"
          fi
          if [ -d runtime/grammars/sources ]; then
            rm -rf runtime/grammars/sources
          fi
          cp -r runtime dist
          tar cJf helix-${{ matrix.build }}.tar.xz dist/*

      - name: Upload helix-${{ matrix.build }}.tar.xz to artifacts
        uses: actions/upload-artifact@v7
        if: env.preview == 'true'
        with:
          name: helix_25.7.1-1_${{ matrix.build }}.tar.xz
          path: helix-${{ matrix.build }}.tar.xz
          archive: false

      - name: Upload helix-${{ matrix.build }}.tar.xz to release
        uses: svenstaro/upload-release-action@29e53e917877a24fad85510ded594ab3c9ca12de # 2.11.5
        if: env.preview == 'false'
        with:
          repo_token: ${{ secrets.GITHUB_TOKEN }}
          file: helix-${{ matrix.build }}.tar.xz
          tag: ${{ github.ref_name }}
          overwrite: true
